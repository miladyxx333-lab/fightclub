# ==========================================
# FIGHTCLUB × SOLANA ESCROW - PRODUCTION ENV
# ==========================================

# ── SUPABASE CONF ─────────────────────────
# The project URL from your Supabase Dashboard
SUPABASE_URL="https://your-project.supabase.co"
# The service_role secret key (requires bypass RLS for API insertions)
# WARNING: NEVER EXPOSE TO FRONTEND! Use ANON key on the frontend!
SUPABASE_KEY="eyJh...YOUR_SERVICE_ROLE_KEY..."

# ── SOLANA RPC ────────────────────────────
# The mainnet RPC endpoint (Helius, QuickNode, Triton, etc.)
# Fallback is usually api.mainnet-beta.solana.com, but highly throttled.
SOLANA_RPC="https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY"

# ── ANCHOR SMART CONTRACT ─────────────────
# The deployed Escrow program ID on Mainnet
PROGRAM_ID="FiGHt1111111111111111111111111111111111111"

# ── SECURITY & CORS ───────────────────────
# The domain of the frontend app (e.g. Vercel, Netlify) to restrict API access.
ALLOWED_ORIGIN="https://fightclub.vercel.app"

# ── MERCHANT / ESCROW AUTHORITY ───────────
# The House/Resolution authority wallet config
# Wallet pubkey that receives the 3% cut.
MERCHANT_WALLET="e6uU5apmNZrUX4L2fCZ7hupZMwofS3JUNXEHcSxqcBD"
# The Private Key in base58 (exports from Phantom or CLI)
# This key autonomously signs the 'resolve_fight' payout instructions!
MERCHANT_PRIVATE_KEY="YOUR_BASE_58_EXACT_PRIVATE_KEY_STRING"

# ==========================================
# IMPORTANT MAINNET CHECKLIST:
# [ ] Update arena.js CONFIG.AUTHORITY_PUBKEY to exactly match MERCHANT_WALLET.
# [ ] Update escrow_client.js PROGRAM_ID to match the deployed PROGRAM_ID.
# [ ] Replace 'devnet' string in frontend Wallet/Connection instances to 'mainnet-beta'.
# ==========================================
